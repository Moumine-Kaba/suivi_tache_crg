# Backend d'authentification - Crédit Rural de Guinée
# Copier vers .env et renseigner les valeurs

PORT=3001
NODE_ENV=development

# Domaine email autorisé (personnel CRG uniquement)
ALLOWED_EMAIL_DOMAIN=creditruralgn.com

# Base de données PostgreSQL (Supabase)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=
# Ou variables Supabase
SUPABASE_DB_URL=

# Supabase (création utilisateurs, envoi email confirmation)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# JWT (optionnel - Supabase gère les tokens)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# reCAPTCHA v3 (optionnel - protection bots)
# Créer une clé sur https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=

# CORS - Origines autorisées (séparées par virgule)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,https://missions.crg.gn

# Rate limiting
# max inscriptions par fenêtre (défaut 10)
# max connexions par fenêtre (défaut 20)
